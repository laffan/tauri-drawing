{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "dialog:default",
    "dialog:allow-save",
    "dialog:allow-open",
    "fs:default",
    "fs:allow-read-file",
    "fs:allow-write-file",
    {
      "identifier": "opener:allow-open-url",
      "allow": [
        { "url": "https://*" },
        { "url": "http://*" },
        { "url": "mailto:*" },
        { "url": "tel:*" },
        { "url": "obsidian://*" },
        { "url": "zotero://*" }
      ]
    }
  ]
}
